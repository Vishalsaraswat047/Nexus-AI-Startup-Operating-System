{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/operations/(?<companyId>[^/]+)/(.+)",
      "dest": "/api/index?companyId=$<companyId>&path=$2"
    },
    {
      "src": "/api/operations/(?<companyId>[^/]+)",
      "dest": "/api/index?companyId=$<companyId>"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ],
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}